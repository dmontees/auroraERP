{
  "name": "Aurora-erp",
  "private": true,
  "version": "3.0.9",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Dani Montes",
  "description": "Aurora - Gestió de producció audiovisual",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc",
    "check:electron": "node --check electron/main.cjs && node --check electron/preload.js",
    "test:critical": "node scripts/test-updater-utils.mjs && node scripts/test-critical-contracts.mjs",
    "check": "npm run typecheck && npm run test:critical && npm run check:electron",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "set NODE_ENV=development && electron .",
    "electron:build": "tsc && vite build && electron-builder",
    "electron:build:mac": "tsc && vite build && electron-builder --mac --publish never",
    "electron:build:win": "tsc && vite build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@types/node-forge": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "node-forge": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "build": {
    "appId": "com.aurora.erp",
    "productName": "Aurora",
    "publish": {
      "provider": "github",
      "owner": "dmontees",
      "repo": "auroraERP",
      "releaseType": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "minimumSystemVersion": "10.13.0"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Aurora ${version}",
      "icon": "build/icon.icns",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
