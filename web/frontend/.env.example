# Copia com .env.local per a desenvolupament local
# En producció, la URL relativa /api funciona automàticament si
# el frontend i l'API estan al mateix domini.

# URL base de l'API PHP (sense barra final)
# Exemples:
#   Producció (mateix domini):  VITE_API_URL=/api
#   Producció (subdomini):      VITE_API_URL=https://erp.tudomini.com/api
#   Desenvolupament local:      VITE_API_URL=http://localhost/aurora/api
VITE_API_URL=/api
